{
  "id": "/",
  "name": "VistoriaPro - FUJAMA",
  "short_name": "VistoriaPro",
  "description": "Sistema de vistoria de campo com GPS, fotos georreferenciadas e exportação KML",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "tabbed",
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "orientation": "portrait",
  "background_color": "#060d1a",
  "theme_color": "#0a1628",
  "lang": "pt-BR",
  "dir": "ltr",
  "categories": [
    "utilities",
    "productivity",
    "navigation"
  ],
  "iarc_rating_id": "",
  "prefer_related_applications": false,
  "related_applications": [],
  "icons": [
    {
      "src": "icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon-384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tela inicial do VistoriaPro"
    },
    {
      "src": "icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "wide",
      "label": "VistoriaPro em modo landscape"
    }
  ],
  "shortcuts": [
    {
      "name": "Nova Vistoria",
      "short_name": "Nova",
      "description": "Iniciar uma nova vistoria de campo",
      "url": "./index.html?action=nova",
      "icons": [
        {
          "src": "icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Vistorias Realizadas",
      "short_name": "Histórico",
      "description": "Ver vistorias anteriores",
      "url": "./index.html?action=lista",
      "icons": [
        {
          "src": "icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/vnd.google-earth.kml+xml": [
          ".kml"
        ],
        "application/zip": [
          ".zip"
        ]
      },
      "icons": [
        {
          "src": "icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+vistoriapro",
      "url": "./index.html?protocolo=%s"
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "image/*",
            "application/vnd.google-earth.kml+xml"
          ]
        }
      ]
    }
  },
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "handle_links": "preferred",
  "scope_extensions": [],
  "widgets": [
    {
      "name": "VistoriaPro Status",
      "short_name": "Vistoria",
      "description": "Status da vistoria em andamento",
      "tag": "vistoria-status",
      "template": "generic-card",
      "ms_ac_template": "widgets/vistoria-status.json",
      "data": "./index.html?widget=status",
      "type": "application/json",
      "screenshots": [
        {
          "src": "icons/icon-192.png",
          "sizes": "192x192",
          "label": "Widget de status"
        }
      ],
      "icons": [
        {
          "src": "icons/icon-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 300
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "window_controls_overlay": {
    "color": "#0a1628"
  },
  "note_taking": {
    "new_note_url": "./index.html?action=nova"
  },
  "tab_strip": {
    "home_tab": {
      "icons": [
        {
          "src": "icons/icon-96.png",
          "sizes": "96x96"
        }
      ],
      "scope_pattern": {
        "pathname": "/*"
      }
    },
    "new_tab_button": {
      "url": "./index.html?action=nova"
    }
  }
}